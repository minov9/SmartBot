/* pages/welcome/welcome.wxss */
/* Apple iOS Native Style */

.welcome-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: #FFFFFF;
  box-sizing: border-box;
}

/* ==================== Hero 区域 ==================== */
.hero-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 48rpx 40rpx;
}

.app-icon {
  width: 180rpx;
  height: 180rpx;
  background: #007AFF;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
  /* iOS App Icon 风格阴影 */
  box-shadow:
    0 4rpx 12rpx rgba(0, 122, 255, 0.15),
    0 20rpx 40rpx rgba(0, 122, 255, 0.20);
}

.icon-emoji {
  font-size: 80rpx;
  /* 让 emoji 稍微偏白 */
  filter: brightness(1.1);
}

.app-name {
  font-size: 56rpx;
  font-weight: 700;
  color: #000000;
  letter-spacing: -1rpx;
  margin-bottom: 8rpx;
}

.app-tagline {
  font-size: 32rpx;
  color: #86868B;
  font-weight: 400;
}

/* ==================== 功能区域 ==================== */
.features-section {
  padding: 32rpx 48rpx 24rpx;
}

.feature-card {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
}

.feature-card:last-child {
  border-bottom: none;
}

.feature-icon {
  font-size: 36rpx;
  width: 64rpx;
  height: 64rpx;
  background: #F5F5F7;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.feature-content {
  flex: 1;
}

.feature-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #1D1D1F;
  margin-bottom: 4rpx;
  letter-spacing: -0.5rpx;
}

.feature-desc {
  display: block;
  font-size: 26rpx;
  color: #86868B;
  font-weight: 400;
}

/* ==================== 操作区域 ==================== */
.action-section {
  padding: 24rpx 48rpx;
  padding-bottom: calc(48rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
}

.primary-btn {
  width: 100%;
  height: 112rpx;
  background: #007AFF;
  color: #FFFFFF;
  font-size: 34rpx;
  font-weight: 600;
  border-radius: 28rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  letter-spacing: -0.5rpx;
  /* iOS 按钮风格阴影 */
  box-shadow: 0 8rpx 24rpx rgba(0, 122, 255, 0.25);
}

.primary-btn:active {
  background: #0066D6;
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(0, 122, 255, 0.20);
}

.secondary-link {
  text-align: center;
  padding: 32rpx;
  color: #007AFF;
  font-size: 30rpx;
  font-weight: 500;
}

.secondary-link:active {
  opacity: 0.6;
}
