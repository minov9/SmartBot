/* pages/settings/settings.wxss */
/* Apple iOS 设置风格 */

.settings-page {
  min-height: 100vh;
  padding: 24rpx;
  background: #F2F2F7;
  box-sizing: border-box;
}

/* ==================== Section Card ==================== */
.section {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 0;
  margin-bottom: 32rpx;
  overflow: hidden;
}

.section-title {
  font-size: 26rpx;
  font-weight: 400;
  color: #8E8E93;
  text-transform: uppercase;
  letter-spacing: 1rpx;
  padding: 24rpx 32rpx 12rpx;
  background: transparent;
  border: none;
  margin: 0;
}

/* ==================== Form Item ==================== */
.form-item {
  padding: 0 32rpx;
  border-bottom: 1rpx solid #E5E5EA;
  margin: 0;
}

.form-item:last-child {
  border-bottom: none;
}

.input-label {
  display: block;
  font-size: 28rpx;
  font-weight: 400;
  color: #8E8E93;
  padding: 24rpx 0 8rpx;
  margin: 0;
}

/* ==================== Picker ==================== */
.picker-value {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 88rpx;
  padding: 20rpx 0;
  font-size: 32rpx;
  color: #000000;
  background: transparent;
  border: none;
  border-radius: 0;
}

.picker-arrow {
  color: #C7C7CC;
  font-size: 28rpx;
}

/* ==================== Input ==================== */
.settings-page .input {
  width: 100%;
  min-height: 88rpx;
  padding: 20rpx 0;
  background: transparent;
  border: none;
  border-radius: 0;
  font-size: 32rpx;
  color: #000000;
  box-sizing: border-box;
}

.settings-page .input::placeholder {
  color: #C7C7CC;
}

/* ==================== Input with Action ==================== */
.input-with-action {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding-bottom: 20rpx;
}

.input-with-action .input {
  flex: 1;
  min-width: 0;
  padding: 0;
  min-height: 48rpx;
}

.input-action {
  flex-shrink: 0;
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F2F2F7;
  border-radius: 50%;
  font-size: 32rpx;
  border: none;
}

.input-action:active {
  background: #E5E5EA;
}

.input-action.loading {
  animation: spin 1s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* ==================== Model List ==================== */
.model-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  padding: 16rpx 0 24rpx;
}

.model-item {
  padding: 12rpx 24rpx;
  background: #F2F2F7;
  border-radius: 999rpx;
  font-size: 26rpx;
  color: #000000;
  border: none;
}

.model-item:active {
  background: #E5E5EA;
}

.model-item.active {
  background: #007AFF;
  color: #FFFFFF;
}

/* ==================== Action Buttons ==================== */
.actions {
  display: flex;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.actions .btn {
  flex: 1;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 20rpx;
  border: none;
}

.actions .btn-secondary {
  background: #FFFFFF;
  color: #007AFF;
}

.actions .btn-secondary:active {
  background: #F2F2F7;
}

.actions .btn-primary {
  background: #007AFF;
  color: #FFFFFF;
}

.actions .btn-primary:active {
  background: #0066DD;
}

/* ==================== Tips ==================== */
.tips {
  background: transparent;
  padding: 0 16rpx;
  box-shadow: none;
  border-radius: 0;
}

.tip-title {
  font-size: 26rpx;
  font-weight: 400;
  color: #8E8E93;
  text-transform: uppercase;
  letter-spacing: 1rpx;
  margin-bottom: 12rpx;
}

.tip-item {
  font-size: 26rpx;
  color: #8E8E93;
  margin-bottom: 8rpx;
  line-height: 1.6;
}
